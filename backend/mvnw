#!/bin/sh

MAVEN_HOME="${MAVEN_HOME:-$HOME/.m2/wrapper/dists/apache-maven-3.9.10/a38810a491b03367137adfdfbe7d14c4}"

MVN_CMD="$MAVEN_HOME/bin/mvn"
if [ ! -f "$MVN_CMD" ] && [ ! -f "$MVN_CMD.cmd" ]; then
  echo "ERROR: Maven not found at $MAVEN_HOME"
  echo "Please ensure Maven 3.9.10 is installed and cached in $MAVEN_HOME"
  exit 1
fi

exec "$MVN_CMD" "$@"
